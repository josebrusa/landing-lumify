# Backend origin (no trailing slash). The app calls `${VITE_API_BASE_URL}/api/...`.
VITE_API_BASE_URL=http://localhost:3000

# Netlify / CI: define VITE_API_BASE_URL in Site configuration → Environment variables
# for Production and Deploy previews, then trigger a new deploy. Vite inlines this at
# build time; if it is missing, the client falls back to same-origin `/api` (no API on
# static hosting → 404 on routes like /api/auth/login).
